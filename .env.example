# Copy this to .env and fill in your values

PORT=5000

# PostgreSQL connection string
# Local:   postgres://postgres:yourpassword@localhost:5432/vigility_db
# Render:  provided automatically as DATABASE_URL
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/vigility_db

JWT_SECRET=replace_this_with_a_long_random_secret_string

# Frontend URL for CORS (change for production)
FRONTEND_URL=http://localhost:5173
